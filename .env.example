# ── Requeridas ────────────────────────────────────────────────────────────────
# API key de Google Gemini (https://aistudio.google.com/apikey).
# Sin ella el servidor NO arranca.
GEMINI_API_KEY=

# Tienda Shopify default (cuando el widget no manda data-shop).
SHOPIFY_SHOP=mi-tienda.myshopify.com

# ── Opcionales ────────────────────────────────────────────────────────────────
# Fallback del nombre de tienda en el saludo (si la home no expone og:site_name).
SHOPIFY_STORE_NAME=

# Puerto del servidor Express. Default: 3000.
PORT=3000

# Vida de las sesiones en memoria (horas). Default: 24.
SESSION_TTL_HOURS=24

# Frecuencia del job de limpieza de sesiones (ms). Default: 3600000 (1h).
CLEANUP_INTERVAL_MS=3600000

# Si se define, GET /api/metrics exige "Authorization: Bearer <token>".
# Sin ella el endpoint solo sirve totales globales (sin desglose por tienda).
# Recomendada en producción.
METRICS_TOKEN=

# Override del endpoint MCP — SOLO para testing local.
MCP_URL=
